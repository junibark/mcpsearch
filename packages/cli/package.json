{
  "name": "mcpsearch-cli",
  "version": "0.1.0",
  "description": "MCPSearch CLI - Discover and install MCP servers for Claude Code, Cursor, Windsurf, and more",
  "type": "module",
  "main": "./dist/index.mjs",
  "bin": {
    "mcp": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "got": "^14.0.0",
    "ora": "^8.0.1",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@mcpsearch/shared": "workspace:*",
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.6",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mcpsearch/mcpsearch.git",
    "directory": "packages/cli"
  },
  "homepage": "https://mcpsearch.com/cli",
  "bugs": {
    "url": "https://github.com/mcpsearch/mcpsearch/issues"
  },
  "author": "MCPSearch",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "package-manager",
    "claude",
    "claude-code",
    "cursor",
    "windsurf",
    "continue",
    "ai",
    "anthropic"
  ],
  "license": "MIT"
}
