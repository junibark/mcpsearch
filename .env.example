# =============================================================================
# MCPSearch Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=mcpsearch-dev
# For local development with LocalStack
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Web Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (DynamoDB)
# -----------------------------------------------------------------------------
DYNAMODB_TABLE=mcp-search-packages-dev
DYNAMODB_ENDPOINT=http://localhost:4566

# -----------------------------------------------------------------------------
# Cache (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_TLS_ENABLED=false

# -----------------------------------------------------------------------------
# Search (OpenSearch)
# -----------------------------------------------------------------------------
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# -----------------------------------------------------------------------------
# Storage (S3)
# -----------------------------------------------------------------------------
PACKAGES_BUCKET=mcp-search-packages-dev
ASSETS_BUCKET=mcp-search-assets-dev
S3_ENDPOINT=http://localhost:4566

# -----------------------------------------------------------------------------
# Authentication (Cognito)
# -----------------------------------------------------------------------------
COGNITO_USER_POOL_ID=us-east-1_xxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=mcpsearch-dev.auth.us-east-1.amazoncognito.com

# For web app (public)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_DOMAIN=mcpsearch-dev.auth.us-east-1.amazoncognito.com

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
SQS_QUEUE_URL=http://localhost:4566/000000000000/mcp-search-jobs-dev
POLL_INTERVAL_MS=5000

# -----------------------------------------------------------------------------
# Email (SES)
# -----------------------------------------------------------------------------
FROM_EMAIL=noreply@mcpsearch.com
SES_REGION=us-east-1

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
ENABLE_METRICS=true
METRICS_PORT=9090
