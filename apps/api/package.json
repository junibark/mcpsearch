{
  "name": "@mcpsearch/api",
  "version": "0.1.0",
  "private": true,
  "description": "MCPSearch API Service",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-secrets-manager": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@mcpsearch/shared": "workspace:*",
    "@opensearch-project/opensearch": "^2.5.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "morgan": "^1.10.0",
    "pino": "^8.17.0",
    "pino-http": "^9.0.0",
    "semver": "^7.6.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.8",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "pino-pretty": "^13.1.3",
    "supertest": "^6.3.4",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.2.0"
  }
}
